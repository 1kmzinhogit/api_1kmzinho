generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StatusPedido {
  PENDENTE
  APROVADO
  REJEITADO
  CANCELADO
}

enum StatusPagamento {
  PENDENTE
  APROVADO
  REJEITADO
  CANCELADO
}

enum Categoria {
  MASCULINO
  FEMININO
  MAIOR_60
  LGBTQIA
}

model Pedido {
  id                String       @id @default(uuid())
  status            StatusPedido @default(PENDENTE)
  codigoPedido      String?      @map("codigo_pedido")
  idPagamento       String?      @unique @map("id_pagamento")
  idPreferencia     String?      @map("id_preferencia")
  referenciaExterna String?      @unique @map("referencia_externa")

  cpf           String
  contato       String
  nomeEvento    String       @map("nome_evento")
  lote          String
  valorIngresso Float        @map("valor_ingresso")
  nomeNaCamisa  String       @map("nome_na_camisa")
  dataNascimento  String       @map("data_nascimento")
  corCamisa     String       @map("cor_camisa")
  equipe        String       @default("")
  categoria     Categoria    @default(MASCULINO)
  total         Float
  nomePessoa    String       @map("nome_pessoa")
  numeroCamisa  String?      @map("numero_camisa")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  itens      ItemPedido[]
  pagamentos Pagamento[]

  @@unique([nomeEvento, lote, codigoPedido])
  @@index([status])
  @@map("pedidos")
}

model ItemPedido {
  id         String @id @default(uuid())
  titulo     String
  quantidade Int
  valorUnit  Float  @map("valor_unitario")
  idPedido   String @map("id_pedido")

  pedido Pedido @relation(fields: [idPedido], references: [id], onDelete: Cascade)

  @@index([idPedido])
  @@map("itens_pedido")
}

model Pagamento {
  id            String          @id @default(uuid())
  idPagamentoMp String          @unique @map("id_pagamento_mp")
  status        StatusPagamento
  respostaRaw   Json            @map("resposta_raw")
  idPedido      String          @map("id_pedido")
  criadoEm      DateTime        @default(now()) @map("criado_em")

  pedido Pedido @relation(fields: [idPedido], references: [id], onDelete: Cascade)

  @@index([idPedido])
  @@map("pagamentos")
}

model ConfigLote {
  id              String      @id @default(uuid())
  nomeEvento      String      @map("nome_evento")
  lote            String
  capacidade      Int
  capacidadeAtual Int         @default(0) @map("capacidade_atual")
  ativo           Boolean     @default(true)
  dataInicio      DateTime?   @map("data_inicio")
  dataFim         DateTime?   @map("data_fim")
  notificado      Boolean     @default(false)
  criadoEm        DateTime    @default(now()) @map("criado_em")

  precos PrecoLote[]

  @@unique([nomeEvento, lote], name: "nomeEvento_lote")
  @@index([nomeEvento])
  @@map("config_lotes")
}

model PrecoLote {
  id           String    @id @default(uuid())
  idConfigLote String    @map("id_config_lote")
  categoria    Categoria
  valor        Float
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now()) @map("criado_em")

  configLote ConfigLote @relation(fields: [idConfigLote], references: [id], onDelete: Cascade)

  @@unique([idConfigLote, categoria], name: "configLote_categoria")
  @@map("precos_lote")
}
