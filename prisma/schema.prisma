generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StatusPedido {
  PENDENTE
  APROVADO
  REJEITADO
  CANCELADO
}

enum StatusPagamento {
  PENDENTE
  APROVADO
  REJEITADO
  CANCELADO
}

model Pedido {
  id                String       @id @default(uuid())
  status            StatusPedido @default(PENDENTE)
  idPagamento       String?      @unique @map("id_pagamento")
  idPreferencia     String?      @map("id_preferencia")
  referenciaExterna String?      @unique @map("referencia_externa")

  cpf           String
  contato       String
  nomeEvento    String @map("nome_evento")
  lote          String
  valorIngresso Float  @map("valor_ingresso")
  nomeNaCamisa  String @map("nome_na_camisa")
  numeroCamisa  String @map("numero_camisa")
  corCamisa     String @map("cor_camisa")
  equipe        String @default("")
  total         Float

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  itens      ItemPedido[]
  pagamentos Pagamento[]

  @@unique([cpf, nomeEvento])
  @@index([status])
  @@map("pedidos")
}

model ItemPedido {
  id         String @id @default(uuid())
  titulo     String
  quantidade Int
  valorUnit  Float  @map("valor_unitario")
  idPedido   String @map("id_pedido")

  pedido Pedido @relation(fields: [idPedido], references: [id], onDelete: Cascade)

  @@index([idPedido])
  @@map("itens_pedido")
}

model Pagamento {
  id            String          @id @default(uuid())
  idPagamentoMp String          @unique @map("id_pagamento_mp")
  status        StatusPagamento
  respostaRaw   Json            @map("resposta_raw")
  idPedido      String          @map("id_pedido")
  criadoEm      DateTime        @default(now()) @map("criado_em")

  pedido Pedido @relation(fields: [idPedido], references: [id], onDelete: Cascade)

  @@index([idPedido])
  @@map("pagamentos")
}

model ConfigLote {
  id         String   @id @default(uuid())
  nomeEvento String   @map("nome_evento")
  lote       String
  capacidade Int
  notificado Boolean  @default(false)
  criadoEm   DateTime @default(now()) @map("criado_em")

  @@unique([nomeEvento, lote], name: "nomeEvento_lote")
  @@map("config_lotes")
}
