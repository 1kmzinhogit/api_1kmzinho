# Copie este arquivo para .env e preencha os valores

PORT=3000
NODE_ENV=development

# URLs usadas no checkout Mercado Pago
FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3000

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@host:porta/bancodedados"
DIRECT_URL="postgresql://usuario:senha@host:porta/bancodedados"

# Mercado Pago
MP_ACCESS_TOKEN=seu_access_token_aqui

# Token administrativo para solicitar reembolsos pela API
REEMBOLSO_ADMIN_TOKEN=troque_por_um_token_forte

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=seu_email@example.com
EMAIL_PASS=sua_senha
